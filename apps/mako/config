# Mako notification daemon — black & white theme, anchored top-right
# Install: pacman -S mako   (or your distro equivalent)
# Reload after edits: makoctl reload

sort=-time
layer=overlay
background-color=#000000d9
text-color=#ffffff
border-color=#ffffff1f
border-radius=8
border-size=1
icons=1
max-icon-size=36
default-timeout=5000
ignore-timeout=1
font=Iosevka Term 11
padding=12
margin=8
width=360
height=110
outer-margin=10
anchor=top-right
max-history=20

[urgency=low]
border-color=#ffffff14
text-color=#ffffffb3

[urgency=normal]
border-color=#ffffff2e
text-color=#ffffff

[urgency=critical]
background-color=#ffffff
text-color=#000000
border-color=#ffffff
default-timeout=0

[mode=do-not-disturb]
invisible=1

[grouped]
format=<b>%s</b>\n%b
